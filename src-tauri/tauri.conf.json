{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "LinkScape",
  "version": "0.1.0",
  "identifier": "app.linkscape.desktop",
  "build": {
    "frontendDist": "./shell"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "LinkScape",
        "url": "https://pdflinkin.vercel.app/board",
        "width": 1280,
        "height": 860,
        "minWidth": 520,
        "minHeight": 480,
        "resizable": true,
        "center": true,
        "decorations": true
      }
    ],
    "security": {
      "csp": null,
      "capabilities": ["default"]
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.ico"
    ],
    "windows": {
      "nsis": {
        "installMode": "currentUser",
        "languages": ["Korean", "English"]
      }
    }
  }
}
